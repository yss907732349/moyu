# 根环境变量样例。真实敏感值不要提交到仓库。
NODE_ENV=development

# API
API_PORT=3000
API_HOST=0.0.0.0
ADMIN_CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
DATABASE_URL="mysql://moyuxia:password@localhost:3306/moyuxia"
APP_AUTH_TOKEN_SECRET="replace-with-local-dev-secret"
APP_AUTH_TOKEN_TTL_SECONDS=2592000
TEMP_CURRENT_USER_ID="dev-temp-user"
ALLOW_TEMP_CURRENT_USER_FALLBACK=true
COMMUNITY_MEDIA_PUBLIC_BASE_URL="http://localhost:3000/uploads/community"

# 微信小程序登录。真实 appid 和 secret 不要提交到仓库。
WECHAT_MINIAPP_APPID="replace-with-wechat-miniapp-appid"
WECHAT_MINIAPP_SECRET="replace-with-wechat-miniapp-secret"
WECHAT_LOGIN_MOCK_ENABLED=true
WECHAT_PHONE_NUMBER_MOCK_ENABLED=true
WECHAT_PHONE_NUMBER_MOCK_PHONE="replace-with-mock-phone-number"
WECHAT_PHONE_NUMBER_MOCK_ERROR=

# 社区身份门槛、隐私协议版本和 IP 属地。提审/生产不要关闭身份门槛或 IP 属地展示位。
COMMUNITY_PRIVACY_POLICY_VERSION="2026-06-08"
COMMUNITY_AGREEMENT_VERSION="2026-06-08"
COMMUNITY_IDENTITY_GATE_ENABLED=true
COMMUNITY_PHONE_HASH_SALT="replace-with-community-phone-hash-salt"
COMMUNITY_TRUSTED_PROXY_HEADERS=
COMMUNITY_TRUSTED_PROXY_ADDRS=
TRUSTED_PROXY_IP_HEADERS=
TRUSTED_PROXY_REMOTE_ADDRS=
COMMUNITY_IP_LOCATION_MOCK_LABEL=
COMMUNITY_IP_LOCATION_MOCK_COUNTRY=
COMMUNITY_IP_LOCATION_MOCK_PROVINCE=

# 隐者日报人工采编与 AI 辅助/审核。真实 DeepSeek API Key 不要提交到仓库。
ADMIN_OPERATIONS_TOKEN="dev-admin-token"
DEEPSEEK_API_KEY="replace-with-deepseek-api-key"
DEEPSEEK_MODEL_NAME="deepseek-chat"
AI_CONTENT_MODERATION_MOCK_RESULT=
AI_CONTENT_MODERATION_FORCE_PROVIDER_ERROR=false
WECHAT_CONTENT_SECURITY_ENABLED=false
WECHAT_CONTENT_SECURITY_MOCK_ENABLED=true
WECHAT_CONTENT_SECURITY_MOCK_TEXT_RESULT=pass
WECHAT_CONTENT_SECURITY_MOCK_IMAGE_RESULT=review
WECHAT_CONTENT_SECURITY_FORCE_PROVIDER_ERROR=false
WECHAT_CONTENT_SECURITY_TIMEOUT_MS=3000
WECHAT_CONTENT_SECURITY_IMAGE_CALLBACK_TOKEN="replace-with-callback-token"
WECHAT_CONTENT_SECURITY_IMAGE_CALLBACK_MAX_DELAY_SECONDS=7200
# 本机 DNS 无法直连 api.deepseek.com 时可显式走 Clash/Mihomo HTTP mixed 代理。
# 例如：DEEPSEEK_PROXY_URL="http://127.0.0.1:7897"
DEEPSEEK_PROXY_URL=

# 聚推客 CPS 补给铺。apikey 只允许配置在服务端环境中，小程序端不得持有。
JUTUIKE_API_KEY="replace-with-jutuike-api-key"
JUTUIKE_TRANSFER_URL="http://api.jutuike.com/union/act"
# Node 直连无法解析聚推客域名时可显式配置；未配置时会复用 DEEPSEEK_PROXY_URL。
JUTUIKE_PROXY_URL=

# 小程序和管理后台 Vite 环境变量。真机调试时把 localhost 改成电脑局域网 IP。
VITE_API_BASE_URL="http://localhost:3000"
VITE_WECHAT_LOGIN_MOCK_ENABLED=true

# 节假日同步/验证脚本。默认使用当前年和下一年，可按需显式覆盖。
HOLIDAY_SYNC_YEARS=
HOLIDAY_VERIFY_YEAR=
